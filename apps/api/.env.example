# PostgreSQL (Neon) — pooled connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# HS256 secret for dashboard session JWTs — generate with `openssl rand -hex 32`
AUTH_JWT_SECRET="replace-with-openssl-rand-hex-32-output"

# API port (web dev server takes 3000)
PORT=4000

# Domain bound into wallet sign messages (must match what the web app renders); nonce TTL in seconds
AUTH_DOMAIN="localhost:3000"
AUTH_NONCE_TTL_SECONDS=300
