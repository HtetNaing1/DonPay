# PostgreSQL (Neon) — pooled connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# HS256 secret for dashboard session JWTs — generate with `openssl rand -hex 32`
AUTH_JWT_SECRET="replace-with-openssl-rand-hex-32-output"

# API port (web dev server takes 3000)
PORT=4000

# Domain bound into wallet sign messages (must match what the web app renders); nonce TTL in seconds
AUTH_DOMAIN="localhost:3000"
AUTH_NONCE_TTL_SECONDS=300

# Rates (CoinGecko) — API key optional (demo tier); cache and quote-lock windows in seconds
# COINGECKO_API_KEY="CG-..."
RATE_CACHE_TTL_SECONDS=60
QUOTE_LOCK_SECONDS=600

# Public origin of the web app — checkout URLs are built from this
WEB_BASE_URL="http://localhost:3000"

# Solana JSON-RPC endpoint (devnet only in v1; use your Helius devnet URL in deploys)
SOLANA_RPC_URL="https://api.devnet.solana.com"
# SPL mint accepted as USDC (default: Circle devnet USDC)
USDC_MINT="4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU"

# Redis — backs the BullMQ watcher queue (dev: docker run -d --name donpay-redis -p 6379:6379 redis:7-alpine)
REDIS_URL="redis://localhost:6379"
# Watcher cadence: active poll, post-expiry tail poll, tail duration, RPC-error backoff ceiling
WATCH_POLL_MS=3000
WATCH_TAIL_POLL_MS=600000
WATCH_TAIL_HOURS=24
WATCH_MAX_BACKOFF_MS=60000

# Webhook outbox dispatcher: sweep cadence, request timeout, retry policy (attempts → dead-letter)
WEBHOOK_POLL_MS=2000
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_BACKOFF_BASE_MS=30000
